{
  "name": "mcc-finance-planner",
  "version": "0.3.0",
  "private": true,
  "description": "Cross-platform personal finance planner built with Electron and React with local storage.",
  "author": "Michael MPJ",
  "license": "MIT",
  "homepage": "https://michael-mpj.github.io/MCC-Finance-Planner",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:dist": "vite build && electron-builder --publish=never",
    "predeploy": "vite build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "bootstrap": "^5.3.3",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "firebase": "^12.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.14.0",
    "vercel": "^54.17.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.0.0",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "prettier": "^3.3.3",
    "vite": "^8.1.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "^2.1.5",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.mcc.finance-planner",
    "productName": "MCC Finance Planner",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ]
  }
}
