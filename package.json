{
  "name": "mcc-finance-planner",
  "version": "0.3.0",
  "private": true,
  "description": "Cross-platform personal finance planner built with React and Vite.",
  "author": "Michael MPJ",
  "license": "MIT",
  "homepage": "https://mcc-finance-planner.vercel.app",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\""
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "bootstrap": "^5.3.3",
    "exceljs": "^3.4.0",
    "file-saver": "^2.0.5",
    "firebase": "^12.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.14.0",
    "vercel": "^50.41.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.0.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "prettier": "^3.3.3",
    "vite": "^8.1.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.mcc.finance-planner",
    "productName": "MCC Finance Planner",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ]
  }
}
