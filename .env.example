# MCC Finance Planner Environment Variables
# Firebase Authentication & Firestore (required for cloud sync)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google Drive API (Optional - for import/export features)
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_GOOGLE_API_KEY=your_google_api_key

# Vercel Analytics (Optional - for usage analytics)
VITE_VERCEL_ANALYTICS_ID=your_vercel_analytics_id

# Application Settings
VITE_APP_NAME=MCC Finance Planner
VITE_APP_VERSION=2.0.0
